# Copy to .env for local runs (docker-compose reads it too).
# Never commit the real .env.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated origins allowed to call the API in dev (Vite dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Trusted origins for CSRF when served behind HTTPS in prod (comma-separated).
CSRF_TRUSTED_ORIGINS=

# Leave DATABASE_URL empty to use the bundled SQLite file.
# Example Postgres: postgres://user:pass@db:5432/otsu_ems
DATABASE_URL=

# Demo credentials created by `python manage.py seed_demo`.
SEED_ADMIN_EMAIL=admin@otsu.test
SEED_ADMIN_PASSWORD=admin12345
SEED_EMPLOYEE_PASSWORD=employee12345
